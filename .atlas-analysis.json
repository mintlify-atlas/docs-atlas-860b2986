  "keyFeatures": [
    "Role-based access control with hierarchical permissions",
    "Maker-checker approval workflow for inventory entries",
    "FIFO-based batch tracking with expiration dates",
    "Daily attendance and meal planning",
    "Real-time inventory stock monitoring",
    "Comprehensive audit logging",
    "Portion yield management",
    "Supabase authentication and PostgreSQL backend"
